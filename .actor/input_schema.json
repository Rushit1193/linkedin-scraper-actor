{
    "title": "LinkedIn URL Collector",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "customerName": {
            "title": "Customer Name",
            "type": "string",
            "description": "Enter customer name",
            "editor": "textfield"
        },
        "serviceName": {
            "title": "Service Name",
            "type": "string",
            "description": "Enter service name",
            "editor": "textfield",
            "default": "LinkedIn Scraper"
        },
        "serviceRequestTagName": {
            "title": "Service Request Tag Name",
            "type": "string",
            "description": "Enter service request tag name",
            "editor": "textfield"
        },
        "inputMode": {
            "title": "Input Mode",
            "type": "string",
            "description": "Choose how to provide LinkedIn URLs",
            "editor": "select",
            "enum": ["manual", "bulk"],
            "enumTitles": ["Manual Input", "Bulk CSV Upload"],
            "default": "manual"
        },
        "linkedinUrls": {
            "title": "LinkedIn URLs (Manual)",
            "type": "array",
            "description": "Add LinkedIn profile URLs one by one",
            "editor": "stringList",
            "prefill": [
                "https://www.linkedin.com/in/example-profile"
            ]
        },
        "csvFileUrl": {
            "title": "CSV File URL (Bulk Upload)",
            "type": "string",
            "description": "URL of CSV file containing LinkedIn URLs",
            "editor": "textfield"
        }
    },
    "required": ["customerName", "inputMode"]
}
